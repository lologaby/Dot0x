---
import Layout from '../../layouts/Layout.astro';
import ParticleBackground from '../../components/ParticleBackground.astro';
import { useTranslations } from '../../i18n/utils';
const t = useTranslations('en');
---
<Layout title="Automation & Innovation">
  <!-- Hero Section -->
  <section class="relative pt-32 pb-20 md:pt-48 md:pb-32 overflow-hidden border-b border-white/10">
    <ParticleBackground />
    <div class="absolute inset-x-0 -top-40 -z-10 transform-gpu overflow-hidden blur-3xl sm:-top-80 pointer-events-none" aria-hidden="true">
      <div class="relative left-[calc(50%-11rem)] aspect-[1155/678] w-[36.125rem] -translate-x-1/2 rotate-[30deg] bg-gradient-to-tr from-zinc-800 to-zinc-400 opacity-20 sm:left-[calc(50%-30rem)] sm:w-[72.1875rem]"></div>
    </div>
    
    <div class="max-w-7xl mx-auto px-6 text-center relative z-10">
      <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-8 relative inline-block">
        <span class="block text-white pb-2 relative z-10 drop-shadow-lg">Empower Your Business with</span>
        
        <!-- Video masked text -->
        <div class="relative inline-block overflow-hidden rounded-xl">
          <video autoPlay loop muted playsInline class="absolute inset-0 w-full h-full object-cover z-0 pointer-events-none mix-blend-screen mix-blend-lighten" style="-webkit-mask-image: url(#text-mask); mask-image: url(#text-mask);">
            <source src="/videos/abstract-metal.mp4" type="video/mp4" />
          </video>
          
          <span class="relative z-10 bg-clip-text text-transparent bg-cover bg-center" style="background-image: url('/videos/abstract-metal.mp4'); -webkit-text-fill-color: transparent;">
             <span class="metallic-gradient block relative z-20 mix-blend-overlay">AI Agents & Automation</span>
             <!-- Fallback for browsers that don't support video mask is the metallic gradient above natively -->
             <!-- We use a CSS trick to actually mask the video -->
          </span>
          
           <div class="relative z-10 text-transparent bg-clip-text font-extrabold pb-4 pt-1">
              <span class="bg-black/50 text-transparent bg-clip-text backdrop-blur-sm" style="background-image: url('/videos/abstract-metal.mp4');">
                  <span class="video-text-mask relative z-20">AI Agents & Automation</span>
              </span>
           </div>
        </div>
      </h1>
      <p class="mt-6 text-lg md:text-xl text-neutral-400 max-w-3xl mx-auto mb-10 leading-relaxed">
        {t('hero.subtitle')}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mt-10">
        <a href="/en/services" class="px-8 py-4 bg-white text-black font-semibold rounded-full hover:bg-neutral-200 transition-all shadow-[0_0_20px_rgba(255,255,255,0.3)] hover:shadow-[0_0_30px_rgba(255,255,255,0.5)]">
          {t('hero.cta')}
        </a>
        <a href="tel:7874609493" class="px-8 py-4 glass-panel glass-panel-hover rounded-full text-white font-medium flex items-center gap-2">
          Call Now
        </a>
      </div>
    </div>
  </section>

  <!-- Core Services Summary -->
  <section class="py-24 relative">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl font-bold metallic-gradient mb-4">Our Services</h2>
        <p class="text-neutral-400">Premium technological solutions for your company.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Service 1 -->
        <div class="glass-panel p-8 rounded-2xl glass-panel-hover group">
          <div class="w-12 h-12 bg-white/10 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"></path><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Task Automation</h3>
          <p class="text-neutral-400 text-sm leading-relaxed">We optimize your workflows by removing repetitive tasks so you can focus on what truly matters.</p>
        </div>

        <!-- Service 2 -->
        <div class="glass-panel p-8 rounded-2xl glass-panel-hover group">
          <div class="w-12 h-12 bg-white/10 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12h4l2-9 5 18 3-9h5"></path></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Google SEO</h3>
          <p class="text-neutral-400 text-sm leading-relaxed">We position your website at the top of Google searches to generate more local and international clients.</p>
        </div>

        <!-- Service 3 -->
        <div class="glass-panel p-8 rounded-2xl glass-panel-hover group md:col-span-2 lg:col-span-1 border-white/20 bg-white/5 relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-zinc-500/10 to-transparent"></div>
          <div class="relative z-10">
            <div class="w-12 h-12 bg-white/20 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
            </div>
            <h3 class="text-xl font-bold text-white mb-3">Premium AI Agents</h3>
            <p class="text-neutral-400 text-sm leading-relaxed mb-4">We develop advanced AI assistants for sales, technical support, and real-time data analysis.</p>
            <span class="inline-block px-3 py-1 bg-white text-black text-xs font-bold rounded-full">Experimental & Exclusive</span>
          </div>
        </div>
      </div>
      
      <div class="mt-12 text-center">
         <a href="/en/services" class="inline-flex items-center gap-2 text-white font-medium hover:text-neutral-300 transition-colors group">
            View full catalog
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
         </a>
      </div>
    </div>
  </section>
</Layout>
