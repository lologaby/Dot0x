---
import Layout from '../../layouts/Layout.astro';
import ParticleBackground from '../../components/ParticleBackground.astro';
import { useTranslations } from '../../i18n/utils';
const t = useTranslations('en');
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---
<Layout title="Automated Solutions & ROI">
  <!-- Hero Section (The Hook) -->
  <section class="relative pt-32 pb-24 md:pt-48 md:pb-40 overflow-hidden border-b border-white/10">
    <ParticleBackground />
    <div class="absolute inset-x-0 -top-40 -z-10 transform-gpu overflow-hidden blur-3xl sm:-top-80 pointer-events-none" aria-hidden="true">
      <div class="relative left-[calc(50%-11rem)] aspect-[1155/678] w-[36.125rem] -translate-x-1/2 rotate-[30deg] bg-gradient-to-tr from-zinc-800 to-zinc-400 opacity-20 sm:left-[calc(50%-30rem)] sm:w-[72.1875rem]"></div>
    </div>
    
    <div class="max-w-7xl mx-auto px-6 text-center relative z-10">
      <h1 class="text-5xl md:text-7xl lg:text-8xl font-extrabold tracking-tight mb-8 relative inline-block leading-tight">
        <div class="relative inline-block overflow-hidden pb-4">
          <!-- The video itself -->
          <video autoPlay loop muted playsInline class="absolute inset-0 w-full h-full object-cover z-0 hidden md:block" style="mix-blend-mode: screen;">
            <source src={`${base}/videos/abstract-metal.mp4`} type="video/mp4" />
          </video>
          
          <!-- The text that masks it -->
          <span class="relative z-10 bg-black text-transparent bg-clip-text font-black" style="mix-blend-mode: multiply;">
             {t('hero.title')}
          </span>
          
          <!-- Fallback layer for when video doesn't load/mobile, sits underneath -->
          <span class="absolute inset-0 z-[-1] metallic-gradient flex items-center justify-center font-black">
             {t('hero.title')}
          </span>
        </div>
      </h1>
      <p class="mt-6 text-lg md:text-2xl text-neutral-300 max-w-4xl mx-auto mb-12 leading-relaxed font-light">
        {t('hero.subtitle')}
      </p>
      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center mt-10">
        <a href="tel:7874609493" class="w-full sm:w-auto px-8 py-5 bg-white text-black text-lg font-bold rounded-full hover:bg-neutral-200 transition-all shadow-[0_0_20px_rgba(255,255,255,0.3)] hover:shadow-[0_0_40px_rgba(255,255,255,0.6)] hover:scale-105 active:scale-95 flex items-center justify-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          {t('hero.cta')}
        </a>
        <a href={`${base}/en/services`} class="w-full sm:w-auto px-8 py-5 glass-panel glass-panel-hover rounded-full text-white text-lg font-medium flex items-center justify-center gap-2 hover:bg-white/10 transition-colors">
          View Catalog
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Pain Points Section (The Agitation) -->
  <section class="py-24 relative bg-black/50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl font-bold text-white mb-6">{t('pain.title')}</h2>
        <div class="w-24 h-1 bg-red-600/80 mx-auto rounded-full"></div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Pain 1 -->
        <div class="glass-panel p-8 rounded-2xl border-t-4 border-t-red-500/50 hover:border-t-red-500 transition-colors">
          <div class="w-14 h-14 bg-red-500/10 rounded-full flex items-center justify-center mb-6">
             <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
          </div>
          <h3 class="text-2xl font-bold text-white mb-4">{t('pain.1.title')}</h3>
          <p class="text-neutral-400 text-lg leading-relaxed">{t('pain.1.desc')}</p>
        </div>
        <!-- Pain 2 -->
        <div class="glass-panel p-8 rounded-2xl border-t-4 border-t-red-500/50 hover:border-t-red-500 transition-colors">
          <div class="w-14 h-14 bg-red-500/10 rounded-full flex items-center justify-center mb-6">
             <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><line x1="19" y1="8" x2="23" y2="12"></line><line x1="23" y1="8" x2="19" y2="12"></line></svg>
          </div>
          <h3 class="text-2xl font-bold text-white mb-4">{t('pain.2.title')}</h3>
          <p class="text-neutral-400 text-lg leading-relaxed">{t('pain.2.desc')}</p>
        </div>
        <!-- Pain 3 -->
        <div class="glass-panel p-8 rounded-2xl border-t-4 border-t-red-500/50 hover:border-t-red-500 transition-colors">
          <div class="w-14 h-14 bg-red-500/10 rounded-full flex items-center justify-center mb-6">
             <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
          </div>
          <h3 class="text-2xl font-bold text-white mb-4">{t('pain.3.title')}</h3>
          <p class="text-neutral-400 text-lg leading-relaxed">{t('pain.3.desc')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Services Summary (The Solution) -->
  <section class="py-32 relative">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-20">
        <h2 class="text-4xl md:text-6xl font-extrabold metallic-gradient mb-6 pb-2">{t('services.title')}</h2>
        <p class="text-2xl text-neutral-400 max-w-3xl mx-auto">{t('services.subtitle')}</p>
      </div>
      
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <!-- Service 1 -->
        <div class="glass-panel p-10 rounded-3xl glass-panel-hover group flex flex-col justify-between">
          <div>
              <div class="w-16 h-16 bg-gradient-to-br from-zinc-300 to-zinc-600 rounded-2xl flex items-center justify-center mb-8 shadow-lg group-hover:scale-110 transition-transform duration-500">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-black" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path></svg>
              </div>
              <h3 class="text-3xl font-bold text-white mb-4">{t('services.1.title')}</h3>
              <p class="text-neutral-400 text-lg leading-relaxed mb-8">{t('services.1.desc')}</p>
          </div>
          <a href={`${base}/en/services`} class="text-white font-bold flex items-center gap-2 group-hover:text-zinc-300 transition-colors">
            See Details <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 group-hover:translate-x-2 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
          </a>
        </div>

        <!-- Service 2 -->
        <div class="glass-panel p-10 rounded-3xl glass-panel-hover group flex flex-col justify-between">
          <div>
              <div class="w-16 h-16 bg-gradient-to-br from-zinc-300 to-zinc-600 rounded-2xl flex items-center justify-center mb-8 shadow-lg group-hover:scale-110 transition-transform duration-500">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-black" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line><polyline points="11 8 11 12 14 15"></polyline></svg>
              </div>
              <h3 class="text-3xl font-bold text-white mb-4">{t('services.2.title')}</h3>
              <p class="text-neutral-400 text-lg leading-relaxed mb-8">{t('services.2.desc')}</p>
          </div>
          <a href={`${base}/en/services`} class="text-white font-bold flex items-center gap-2 group-hover:text-zinc-300 transition-colors">
            See Details <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 group-hover:translate-x-2 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
          </a>
        </div>

        <!-- Service 3 -->
        <div class="glass-panel p-10 rounded-3xl glass-panel-hover group flex flex-col justify-between border-white/30 bg-white/5 relative overflow-hidden shadow-[0_0_30px_rgba(255,255,255,0.05)]">
          <div class="absolute inset-0 bg-gradient-to-br from-zinc-500/10 to-transparent"></div>
          <div class="relative z-10 h-full flex flex-col justify-between">
             <div>
                <div class="w-16 h-16 bg-white rounded-2xl flex items-center justify-center mb-8 shadow-[0_0_20px_rgba(255,255,255,0.5)] group-hover:scale-110 transition-transform duration-500">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-black" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
                </div>
                <h3 class="text-3xl font-bold text-white mb-4">{t('services.3.title')}</h3>
                <p class="text-neutral-400 text-lg leading-relaxed mb-8">{t('services.3.desc')}</p>
             </div>
             <a href={`${base}/en/services`} class="text-white font-bold flex items-center gap-2 group-hover:text-zinc-300 transition-colors">
                See Details <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 group-hover:translate-x-2 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
             </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust / Why Us (The Authority) -->
  <section class="py-24 relative bg-zinc-900/50 border-y border-white/5">
     <div class="max-w-5xl mx-auto px-6 text-center">
        <h2 class="text-4xl font-bold text-white mb-8">{t('trust.title')}</h2>
        <p class="text-xl md:text-2xl text-neutral-300 leading-relaxed font-light">
          {t('trust.desc')}
        </p>
     </div>
  </section>

  <!-- Final CTA (The Close) -->
  <section class="py-32 relative overflow-hidden">
     <!-- Abstract background glow -->
     <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-zinc-800/40 via-transparent to-transparent opacity-60"></div>
     
     <div class="max-w-4xl mx-auto px-6 text-center relative z-10">
        <h2 class="text-5xl md:text-7xl font-extrabold text-white mb-8 tracking-tight drop-shadow-2xl">
           {t('cta.title')}
        </h2>
        <p class="text-xl md:text-2xl text-neutral-400 mb-12">
           {t('cta.subtitle')}
        </p>
        <a href="tel:7874609493" class="inline-flex px-12 py-6 bg-white text-black text-2xl font-bold rounded-full hover:bg-neutral-200 transition-all shadow-[0_0_30px_rgba(255,255,255,0.4)] hover:shadow-[0_0_50px_rgba(255,255,255,0.7)] hover:-translate-y-1 active:translate-y-0 items-center gap-4">
           <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
           {t('cta.button')}
        </a>
        <p class="mt-6 text-neutral-500 font-medium">Toll-free. No commitments.</p>
     </div>
  </section>
</Layout>
