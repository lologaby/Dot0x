---
import Layout from '../../layouts/Layout.astro';
import { useTranslations } from '../../i18n/utils';
const t = useTranslations('en');
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---
<Layout title="About Me">
  <section class="pt-32 pb-20 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      
      <!-- Profile Image -->
      <div class="flex justify-center lg:justify-end">
         <div class="relative w-40 h-40 md:w-56 md:h-56 lg:w-72 lg:h-72 rounded-full overflow-hidden glass-panel ring-1 ring-white/10 shadow-2xl">
            <img src={`${base}/images/profile.jpg`} alt="Alex Berrios Mangual" class="w-full h-full object-cover object-center z-10 relative" />
            <div class="absolute inset-0 bg-gradient-to-tr from-zinc-800 to-zinc-400 opacity-20 z-0"></div>
         </div>
      </div>

      <!-- Bio Content -->
      <div>
        <h1 class="text-4xl md:text-5xl font-bold metallic-gradient mb-6">Alex Berrios Mangual</h1>
        <h2 class="text-xl text-white font-medium mb-8">Founder of Dot0x | Technology Expert</h2>
        
        <div class="space-y-6 text-neutral-400 leading-relaxed">
          <p>
            Hello! I'm Alex Berrios Mangual, an IT Infrastructure Specialist and DevOps Practitioner from Guaynabo, Puerto Rico. I specialize in making enterprise systems actually work—bridging the gap between networking and software to modernize IT infrastructure.
          </p>
          <p>
            Currently, I serve as an IT Specialist for a leading retail group in Puerto Rico, where I manage enterprise environments involving Active Directory, Microsoft 365, Intune, and high-availability POS systems. Previously, I honed my skills as a NOC Technician at WorldNet Telecommunications, managing SLA compliance and configuring enterprise routers and firewalls.
          </p>
          <p>
            My goal with Dot0x is to empower companies by offering enterprise-level solutions tailored to modern needs. From optimizing retail environments with automation to experimenting with AI voice integration, I'm passionate about showing how technology can be your best ally for growth.
          </p>
        </div>

        <div class="mt-10 flex gap-4">
          <a href="https://pr.linkedin.com/in/alex-berrios-mangual-b26b5a241" target="_blank" class="px-6 py-3 bg-[#0a66c2] hover:bg-[#004182] text-white font-semibold rounded-full transition-colors flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
            Connect on LinkedIn
          </a>
        </div>
      </div>

    </div>
  </section>
</Layout>
