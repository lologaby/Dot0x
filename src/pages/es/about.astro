---
import Layout from '../../layouts/Layout.astro';
import { useTranslations } from '../../i18n/utils';
import { Image } from 'astro:assets';
import profileImg from '../../assets/profile.jpg';
const t = useTranslations('es');
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---
<Layout title="Sobre Mí" description="Conoce a Alex Berrios Mangual — Especialista en Infraestructura TI, DevOps y fundador de Dot0x. Ayudando a los negocios de Puerto Rico a crecer con tecnología de nivel empresarial.">
  <section class="pt-32 pb-20 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      
      <!-- Profile Image -->
      <div class="flex justify-center lg:justify-end">
         <div class="relative w-40 h-40 md:w-56 md:h-56 lg:w-72 lg:h-72 rounded-full overflow-hidden glass-panel ring-1 ring-white/10 shadow-2xl">
            <Image src={profileImg} alt="Alex Berrios Mangual" class="w-full h-full object-cover object-center z-10 relative" width={400} />
            <div class="absolute inset-0 bg-gradient-to-tr from-zinc-800 to-zinc-400 opacity-20 z-0"></div>
         </div>
      </div>

      <!-- Bio Content -->
      <div>
        <h1 class="text-4xl md:text-5xl font-bold metallic-gradient mb-6">Alex Berrios Mangual</h1>
        <h2 class="text-xl text-white font-medium mb-8">Fundador de Dot0x | Experto en Tecnología</h2>
        
        <div class="space-y-6 text-neutral-400 leading-relaxed">
          <p>
            ¡Hola! Soy Alex Berrios Mangual, de Bayamón, Puerto Rico. En el papel, soy un Especialista en Infraestructura TI y Profesional DevOps. En la vida real, soy un entusiasta obsesionado con la tecnología que no descansa hasta que lo nuevo funciona.
          </p>
          <p>
            Mi pasión por la automatización nace de pasar horas en mi "homelab", probando distribuciones de Linux, montando máquinas virtuales (VMs) y haciendo pruebas exhaustivas de software (software testing). Esa misma curiosidad y nivel de detalle es lo que aplico hoy como Especialista de TI para un importante grupo minorista, administrando sistemas corporativos complejos (Active Directory, Microsoft 365, sistemas POS de alta disponibilidad) y resolviendo problemas antes de que afecten las ventas.
          </p>
          <p>
            Mi objetivo con Dot0x no es venderte humo ni palabrería técnica. Mi objetivo es tomar esa misma infraestructura robusta de nivel empresarial y esas automatizaciones avanzadas, y ponerlas a trabajar para tu negocio. Si necesitas agentes de IA que respondan por ti 24/7 o sistemas que se sincronicen solos, yo seré la persona detrás del telón asegurándome de que corra impecable.
          </p>
        </div>

        <div class="mt-10 flex gap-4">
          <a href="https://www.linkedin.com/in/alex-berrios-mangual-b26b5a241/" target="_blank" class="px-6 py-3 bg-[#0a66c2] hover:bg-[#004182] text-white font-semibold rounded-full transition-colors flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
            Conectar en LinkedIn
          </a>
        </div>
      </div>

    </div>
  </section>
</Layout>
