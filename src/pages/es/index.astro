---
import Layout from '../../layouts/Layout.astro';
import ParticleBackground from '../../components/ParticleBackground.astro';
import TechStack from '../../components/TechStack.astro';
import { useTranslations } from '../../i18n/utils';
const t = useTranslations('es');
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---
<Layout title="Resultados y Ventas Automatizadas" description="Agentes IA, SEO Local y Automatización para negocios en Puerto Rico. Reduce costos, duplica ventas y trabaja menos — empieza hoy.">

  <!-- ── HERO ─────────────────────────────────── -->
  <section class="relative pt-24 sm:pt-32 md:pt-44 pb-20 md:pb-36 overflow-hidden border-b border-white/10">
    <ParticleBackground />

    <!-- Floating gradient orb -->
    <div class="absolute inset-x-0 -top-40 -z-10 blur-3xl sm:-top-80 pointer-events-none overflow-hidden" aria-hidden="true">
      <div class="relative left-[calc(50%-11rem)] aspect-[1155/678] w-[36.125rem] bg-gradient-to-tr from-zinc-800 to-zinc-400 opacity-20 sm:left-[calc(50%-30rem)] sm:w-[72.1875rem]"
        style="animation: float 9s ease-in-out infinite; transform-origin: center; transform: translateX(-50%) rotate(30deg);">
      </div>
    </div>

    <!-- Video source: visible in section, opacity:0 — full dimensions so Safari plays it -->
    <video id="hero-video-src" loop muted playsinline
      class="absolute inset-0 w-full h-full object-cover pointer-events-none hidden md:block"
      style="opacity:0; z-index:0;" aria-hidden="true">
      <source src={`${base}/videos/abstract-metal.mp4`} type="video/mp4" />
    </video>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 text-center relative z-10">

      <h1 class="text-4xl sm:text-5xl md:text-7xl lg:text-8xl font-extrabold tracking-tight mb-6 md:mb-8 leading-tight hero-enter">
        <!-- Mobile: animated shimmer metallic text -->
        <span class="block md:hidden font-black metallic-shimmer">{t('hero.title')}</span>
        <!-- Desktop: video piped through text via canvas -->
        <span
          id="hero-text-desktop"
          class="hidden md:block font-black"
          style="color:transparent; -webkit-background-clip:text; background-clip:text; background-size:100% 100%; background-image:linear-gradient(135deg,#e4e6ea 0%,#a9adb5 50%,#767a83 100%);"
        >{t('hero.title')}</span>
      </h1>

      <p class="text-base sm:text-lg md:text-2xl text-neutral-300 max-w-4xl mx-auto mb-10 md:mb-12 leading-relaxed font-light hero-enter [animation-delay:160ms]">
        {t('hero.subtitle')}
      </p>

      <div class="flex flex-col sm:flex-row gap-4 sm:gap-6 justify-center items-center hero-enter [animation-delay:320ms]">
        <a href="tel:7874609493"
          class="w-full sm:w-auto px-8 py-4 md:py-5 bg-white text-black text-base md:text-lg font-bold rounded-full hover:bg-neutral-200 transition-all btn-glow-pulse hover:scale-105 active:scale-95 flex items-center justify-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          {t('hero.cta')}
        </a>
        <a href={`${base}/es/services`}
          class="w-full sm:w-auto px-8 py-4 md:py-5 glass-panel glass-panel-hover rounded-full text-white text-base md:text-lg font-medium flex items-center justify-center gap-2 hover:bg-white/10 transition-colors">
          Ver Catálogo
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ── TECH STACK ────────────────────────────── -->
  <TechStack lang="es" />

  <!-- ── PAIN POINTS ───────────────────────────── -->
  <section class="py-20 md:py-24 relative bg-black/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12 md:mb-16 reveal">
        <h2 class="text-3xl md:text-5xl font-bold text-white mb-6">{t('pain.title')}</h2>
        <div class="w-24 h-1 bg-red-600/80 mx-auto rounded-full"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
        <div class="glass-panel p-6 md:p-8 rounded-2xl border-t-4 border-t-red-500/50 hover:border-t-red-500 transition-colors reveal" data-delay="0ms">
          <div class="w-12 h-12 md:w-14 md:h-14 bg-red-500/10 rounded-full flex items-center justify-center mb-5 md:mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 md:w-7 md:h-7 text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
          </div>
          <h3 class="text-xl md:text-2xl font-bold text-white mb-3 md:mb-4">{t('pain.1.title')}</h3>
          <p class="text-neutral-400 text-base md:text-lg leading-relaxed">{t('pain.1.desc')}</p>
        </div>

        <div class="glass-panel p-6 md:p-8 rounded-2xl border-t-4 border-t-red-500/50 hover:border-t-red-500 transition-colors reveal" data-delay="120ms">
          <div class="w-12 h-12 md:w-14 md:h-14 bg-red-500/10 rounded-full flex items-center justify-center mb-5 md:mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 md:w-7 md:h-7 text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><line x1="19" y1="8" x2="23" y2="12"></line><line x1="23" y1="8" x2="19" y2="12"></line></svg>
          </div>
          <h3 class="text-xl md:text-2xl font-bold text-white mb-3 md:mb-4">{t('pain.2.title')}</h3>
          <p class="text-neutral-400 text-base md:text-lg leading-relaxed">{t('pain.2.desc')}</p>
        </div>

        <div class="glass-panel p-6 md:p-8 rounded-2xl border-t-4 border-t-red-500/50 hover:border-t-red-500 transition-colors reveal" data-delay="240ms">
          <div class="w-12 h-12 md:w-14 md:h-14 bg-red-500/10 rounded-full flex items-center justify-center mb-5 md:mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 md:w-7 md:h-7 text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
          </div>
          <h3 class="text-xl md:text-2xl font-bold text-white mb-3 md:mb-4">{t('pain.3.title')}</h3>
          <p class="text-neutral-400 text-base md:text-lg leading-relaxed">{t('pain.3.desc')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── SERVICES SUMMARY ──────────────────────── -->
  <section class="py-24 md:py-32 relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-14 md:mb-20 reveal">
        <h2 class="text-3xl md:text-5xl lg:text-6xl font-extrabold metallic-gradient mb-4 md:mb-6 pb-2">{t('services.title')}</h2>
        <p class="text-lg md:text-2xl text-neutral-400 max-w-3xl mx-auto">{t('services.subtitle')}</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 md:gap-10">
        <div class="glass-panel p-6 md:p-10 rounded-3xl glass-panel-hover group flex flex-col justify-between reveal" data-delay="0ms">
          <div>
            <div class="w-14 h-14 md:w-16 md:h-16 bg-gradient-to-br from-zinc-300 to-zinc-600 rounded-2xl flex items-center justify-center mb-6 md:mb-8 shadow-lg group-hover:scale-110 transition-transform duration-500">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 md:w-8 md:h-8 text-black" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path></svg>
            </div>
            <h3 class="text-2xl md:text-3xl font-bold text-white mb-3 md:mb-4">{t('services.1.title')}</h3>
            <p class="text-neutral-400 text-base md:text-lg leading-relaxed mb-6 md:mb-8">{t('services.1.desc')}</p>
          </div>
          <a href={`${base}/es/services`} class="text-white font-bold flex items-center gap-2 group-hover:text-zinc-300 transition-colors">
            Ver Detalles <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 group-hover:translate-x-2 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
          </a>
        </div>

        <div class="glass-panel p-6 md:p-10 rounded-3xl glass-panel-hover group flex flex-col justify-between reveal" data-delay="120ms">
          <div>
            <div class="w-14 h-14 md:w-16 md:h-16 bg-gradient-to-br from-zinc-300 to-zinc-600 rounded-2xl flex items-center justify-center mb-6 md:mb-8 shadow-lg group-hover:scale-110 transition-transform duration-500">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 md:w-8 md:h-8 text-black" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line><polyline points="11 8 11 12 14 15"></polyline></svg>
            </div>
            <h3 class="text-2xl md:text-3xl font-bold text-white mb-3 md:mb-4">{t('services.2.title')}</h3>
            <p class="text-neutral-400 text-base md:text-lg leading-relaxed mb-6 md:mb-8">{t('services.2.desc')}</p>
          </div>
          <a href={`${base}/es/services`} class="text-white font-bold flex items-center gap-2 group-hover:text-zinc-300 transition-colors">
            Ver Detalles <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 group-hover:translate-x-2 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
          </a>
        </div>

        <div class="glass-panel p-6 md:p-10 rounded-3xl glass-panel-hover group flex flex-col justify-between border-white/30 bg-white/5 relative overflow-hidden shadow-[0_0_30px_rgba(255,255,255,0.05)] reveal" data-delay="240ms">
          <div class="absolute inset-0 bg-gradient-to-br from-zinc-500/10 to-transparent"></div>
          <div class="relative z-10 h-full flex flex-col justify-between">
            <div>
              <div class="w-14 h-14 md:w-16 md:h-16 bg-white rounded-2xl flex items-center justify-center mb-6 md:mb-8 shadow-[0_0_20px_rgba(255,255,255,0.5)] group-hover:scale-110 transition-transform duration-500">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 md:w-8 md:h-8 text-black" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
              </div>
              <h3 class="text-2xl md:text-3xl font-bold text-white mb-3 md:mb-4">{t('services.3.title')}</h3>
              <p class="text-neutral-400 text-base md:text-lg leading-relaxed mb-6 md:mb-8">{t('services.3.desc')}</p>
            </div>
            <a href={`${base}/es/services`} class="text-white font-bold flex items-center gap-2 group-hover:text-zinc-300 transition-colors">
              Ver Detalles <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 group-hover:translate-x-2 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── TRUST ─────────────────────────────────── -->
  <section class="py-20 md:py-24 relative bg-zinc-900/50 border-y border-white/5">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 text-center reveal">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6 md:mb-8">{t('trust.title')}</h2>
      <p class="text-lg md:text-2xl text-neutral-300 leading-relaxed font-light">{t('trust.desc')}</p>
    </div>
  </section>

  <!-- ── FINAL CTA ──────────────────────────────── -->
  <section class="py-20 md:py-32 relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-zinc-800/40 via-transparent to-transparent opacity-60"></div>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center relative z-10 reveal">
      <h2 class="text-4xl sm:text-5xl md:text-7xl font-extrabold text-white mb-6 md:mb-8 tracking-tight drop-shadow-2xl">
        {t('cta.title')}
      </h2>
      <p class="text-lg md:text-2xl text-neutral-400 mb-10 md:mb-12">
        {t('cta.subtitle')}
      </p>
      <a href="tel:7874609493"
        class="inline-flex px-8 md:px-12 py-4 md:py-6 bg-white text-black text-lg md:text-2xl font-bold rounded-full hover:bg-neutral-200 transition-all btn-glow-pulse hover:-translate-y-1 active:translate-y-0 items-center gap-3 md:gap-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 md:w-8 md:h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
        {t('cta.button')}
      </a>
      <p class="mt-5 text-neutral-500 font-medium text-sm md:text-base">Llamada gratuita. Sin compromisos.</p>
    </div>
  </section>

</Layout>

<script>
  function initHeroVideoText() {
    if (!window.matchMedia('(min-width: 768px)').matches) return;

    const textEl = document.getElementById('hero-text-desktop') as HTMLElement | null;
    const video  = document.getElementById('hero-video-src')   as HTMLVideoElement | null;
    if (!textEl || !video) return;

    // Guard: prevent double-init on same element (Astro replaces DOM on navigate)
    if (video.dataset.canvasInit) return;
    video.dataset.canvasInit = '1';

    const canvas = document.createElement('canvas');
    const ctx    = canvas.getContext('2d');
    if (!ctx) return;

    function resize() {
      const rect = textEl!.getBoundingClientRect();
      if (rect.width > 0) {
        canvas.width  = Math.round(rect.width);
        canvas.height = Math.round(rect.height);
      }
    }

    let lastFrame = 0;
    function frame(ts: number) {
      if (ts - lastFrame >= 33 && !video!.paused && canvas.width > 0) {
        lastFrame = ts;
        ctx!.drawImage(video!, 0, 0, canvas.width, canvas.height);
        textEl!.style.backgroundImage = `url("${canvas.toDataURL('image/jpeg', 0.82)}")`;
      }
      requestAnimationFrame(frame);
    }

    resize();
    window.addEventListener('resize', resize);

    // Start loop when video is actually playing
    video.addEventListener('playing', () => { resize(); requestAnimationFrame(frame); }, { once: true });

    // Kick off playback (no autoplay attr, so must call play())
    video.play().catch(() => {});

    // Fallback if video was already playing (e.g. fast navigation)
    if (!video.paused) { resize(); requestAnimationFrame(frame); }
  }

  document.addEventListener('astro:page-load', initHeroVideoText);
  initHeroVideoText();
</script>
