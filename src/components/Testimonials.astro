---
// Testimonials.astro — Social proof section
import { getLangFromUrl, useTranslations } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const testimonials = [
  {
    name: t('testimonials.1.name'),
    role: t('testimonials.1.role'),
    text: t('testimonials.1.text'),
    rating: 5,
    initial: 'C',
    color: 'from-blue-600 to-blue-800',
    metric: lang === 'es' ? '20 hrs/semana ahorradas' : '20 hrs/week saved',
  },
  {
    name: t('testimonials.2.name'),
    role: t('testimonials.2.role'),
    text: t('testimonials.2.text'),
    rating: 5,
    initial: 'M',
    color: 'from-purple-600 to-purple-800',
    metric: lang === 'es' ? '+40% visitas a tienda' : '+40% store visits',
  },
  {
    name: t('testimonials.3.name'),
    role: t('testimonials.3.role'),
    text: t('testimonials.3.text'),
    rating: 5,
    initial: 'J',
    color: 'from-zinc-600 to-zinc-800',
    metric: lang === 'es' ? '2 propiedades extra / mes' : '2 extra properties/month',
  },
];
---

<section class="py-20 md:py-28 relative overflow-hidden" id="testimonials">
  <!-- Background glow -->
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-white/[0.02] to-transparent pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <!-- Header -->
    <div class="text-center mb-14 md:mb-18 reveal">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-white/10 bg-white/5 text-xs font-semibold text-neutral-400 tracking-widest uppercase mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-yellow-400" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        Testimonios verificados
      </div>
      <h2 class="text-3xl md:text-5xl font-bold text-white mb-4">{t('testimonials.title')}</h2>
      <p class="text-neutral-400 text-lg max-w-xl mx-auto">{t('testimonials.subtitle')}</p>
    </div>

    <!-- Cards grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
      {testimonials.map((testimonial, i) => (
        <div
          class="glass-panel rounded-3xl p-8 flex flex-col gap-6 hover:border-white/20 transition-all duration-300 reveal group"
          data-delay={`${i * 120}ms`}
        >
          <!-- Stars -->
          <div class="flex gap-1">
            {Array.from({ length: testimonial.rating }).map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-yellow-400" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            ))}
          </div>

          <!-- Quote text -->
          <blockquote class="text-neutral-300 text-base leading-relaxed flex-1">
            "{testimonial.text}"
          </blockquote>

          <!-- Metric badge -->
          <div class="inline-flex self-start items-center gap-2 px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-xs font-semibold text-white/70">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-green-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
            {testimonial.metric}
          </div>

          <!-- Author -->
          <div class="flex items-center gap-3 pt-2 border-t border-white/10">
            <div class={`w-10 h-10 rounded-full bg-gradient-to-br ${testimonial.color} flex items-center justify-center text-white font-bold text-base flex-shrink-0`}>
              {testimonial.initial}
            </div>
            <div>
              <div class="text-white font-semibold text-sm">{testimonial.name}</div>
              <div class="text-neutral-500 text-xs">{testimonial.role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
