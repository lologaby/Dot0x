---
// Testimonials.astro — "Launch Plan" section (no fake testimonials while building client base)
import { getLangFromUrl, useTranslations } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const CALENDLY = 'https://calendly.com/dot0x/consulta';

const plans = [
  {
    name: t('testimonials.1.name'),
    role: t('testimonials.1.role'),
    text: t('testimonials.1.text'),
    iconPath: 'M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z',
    tagColor: 'text-green-400 border-green-400/30 bg-green-400/10',
  },
  {
    name: t('testimonials.2.name'),
    role: t('testimonials.2.role'),
    text: t('testimonials.2.text'),
    iconPath: 'M11 3a8 8 0 1 0 0 16A8 8 0 0 0 11 3zm10 10-4.35-4.35',
    tagColor: 'text-blue-400 border-blue-400/30 bg-blue-400/10',
  },
  {
    name: t('testimonials.3.name'),
    role: t('testimonials.3.role'),
    text: t('testimonials.3.text'),
    iconPath: 'M2 3h20v14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V3zM8 21h8M12 17v4',
    tagColor: 'text-purple-400 border-purple-400/30 bg-purple-400/10',
  },
];

const tag = lang === 'es' ? 'Precio Lanzamiento' : 'Launch Price';
const ctaText = lang === 'es' ? 'Agendar consulta' : 'Book a consult';
const badge = lang === 'es' ? 'Solo 5 lugares disponibles' : 'Only 5 spots available';
---

<section class="py-20 md:py-28 relative overflow-hidden" id="planes">
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-white/[0.02] to-transparent pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-14 reveal">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-green-400/30 bg-green-400/5 text-xs font-semibold text-green-400 tracking-widest uppercase mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse"></span>
        {badge}
      </div>
      <h2 class="text-3xl md:text-5xl font-bold text-white mb-4">{t('testimonials.title')}</h2>
      <p class="text-neutral-400 text-lg max-w-xl mx-auto">{t('testimonials.subtitle')}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
      {plans.map((plan, i) => (
        <div
          class="glass-panel rounded-3xl p-8 flex flex-col gap-5 hover:border-white/20 transition-all duration-300 reveal group"
          data-delay={`${i * 120}ms`}
        >
          <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-zinc-400 to-zinc-700 flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d={plan.iconPath} />
            </svg>
          </div>

          <span class={`inline-flex self-start items-center gap-1.5 px-2.5 py-1 rounded-full border text-xs font-semibold ${plan.tagColor}`}>
            <span class="w-1.5 h-1.5 rounded-full bg-current animate-pulse"></span>
            {tag}
          </span>

          <div>
            <h3 class="text-xl font-bold text-white mb-1">{plan.name}</h3>
            <p class="text-sm text-neutral-400 font-mono">{plan.role}</p>
          </div>

          <p class="text-neutral-400 text-base leading-relaxed flex-1">{plan.text}</p>

          <a
            href={CALENDLY}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm font-bold text-white group-hover:text-neutral-300 transition-colors mt-auto pt-4 border-t border-white/10"
          >
            {ctaText}
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
