---
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<footer class="border-t border-white/10 bg-black/50 py-16 mt-32">
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-12">
    <div>
      <h3 class="text-2xl font-bold metallic-gradient mb-4">Dot0x</h3>
      <p class="text-sm text-neutral-400 max-w-sm">
        {lang === 'es' 
          ? 'Automatización e innovación desde Puerto Rico para el mundo.' 
          : 'Automation and innovation from Puerto Rico to the world.'}
      </p>
    </div>
    
    <div>
      <h4 class="text-white font-semibold mb-4 text-lg">{lang === 'es' ? 'Enlaces' : 'Quick Links'}</h4>
      <div class="flex flex-col gap-2">
        <a href={useTranslatedPath(lang)('/services')} class="text-sm text-neutral-400 hover:text-white transition">{t('nav.services')}</a>
        <a href={useTranslatedPath(lang)('/about')} class="text-sm text-neutral-400 hover:text-white transition">{t('nav.about')}</a>
      </div>
    </div>

    <div>
       <h4 class="text-white font-semibold mb-4 text-lg">{t('nav.contact')}</h4>
       <div class="flex flex-col gap-2">
         <a href="tel:7874609493" class="text-sm text-neutral-400 hover:text-white transition flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            {t('contact.phone')}
         </a>
         <a href="https://www.linkedin.com/in/alex-berrios-mangual-b26b5a241" target="_blank" rel="noopener noreferrer" class="text-sm text-neutral-400 hover:text-white transition flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
            Alex Berrios (LinkedIn)
         </a>
       </div>
    </div>
  </div>
  
  <div class="max-w-7xl mx-auto px-6 mt-16 pt-8 border-t border-white/5 text-center flex flex-col md:flex-row items-center justify-between text-xs text-neutral-500">
    <p>&copy; {new Date().getFullYear()} Dot0x. All rights reserved.</p>
    <p class="mt-2 md:mt-0">Built with modern tech in Puerto Rico 🇵🇷</p>
  </div>
</footer>
