---
// FAQ.astro — Frequently asked questions with accordion
import { getLangFromUrl, useTranslations } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const faqs = [
  { q: t('faq.1.q'), a: t('faq.1.a') },
  { q: t('faq.2.q'), a: t('faq.2.a') },
  { q: t('faq.3.q'), a: t('faq.3.a') },
  { q: t('faq.4.q'), a: t('faq.4.a') },
  { q: t('faq.5.q'), a: t('faq.5.a') },
];
---

<section class="py-20 md:py-28 relative bg-black/30" id="faq">
  <div class="max-w-3xl mx-auto px-4 sm:px-6">
    <!-- Header -->
    <div class="text-center mb-12 reveal">
      <h2 class="text-3xl md:text-5xl font-bold text-white mb-4">{t('faq.title')}</h2>
      <p class="text-neutral-400 text-lg">{t('faq.subtitle')}</p>
    </div>

    <!-- Accordion -->
    <div class="space-y-3" id="faq-list">
      {faqs.map((faq, i) => (
        <div
          class="glass-panel rounded-2xl overflow-hidden border border-white/5 hover:border-white/15 transition-colors reveal"
          data-delay={`${i * 80}ms`}
        >
          <button
            class="faq-trigger w-full text-left flex items-center justify-between gap-4 px-6 py-5 text-white font-semibold text-base md:text-lg cursor-pointer"
            aria-expanded="false"
          >
            <span class="flex items-start gap-3">
              <span class="text-neutral-500 text-sm font-mono mt-0.5 flex-shrink-0">
                {String(i + 1).padStart(2, '0')}
              </span>
              {faq.q}
            </span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="faq-icon w-5 h-5 flex-shrink-0 text-neutral-400 transition-transform duration-300"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </button>
          <div class="faq-answer hidden px-6 pb-6">
            <div class="pl-8 text-neutral-400 text-base leading-relaxed border-l border-white/10">
              {faq.a}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  function initFAQ() {
    document.querySelectorAll('.faq-trigger').forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const expanded = trigger.getAttribute('aria-expanded') === 'true';
        const answer = trigger.nextElementSibling as HTMLElement;
        const icon = trigger.querySelector('.faq-icon') as HTMLElement;

        // Collapse all
        document.querySelectorAll('.faq-trigger').forEach((t) => {
          t.setAttribute('aria-expanded', 'false');
          const a = t.nextElementSibling as HTMLElement;
          const ic = t.querySelector('.faq-icon') as HTMLElement;
          if (a) a.classList.add('hidden');
          if (ic) ic.style.transform = '';
        });

        // Open clicked (if it was closed)
        if (!expanded) {
          trigger.setAttribute('aria-expanded', 'true');
          answer?.classList.remove('hidden');
          if (icon) icon.style.transform = 'rotate(180deg)';
        }
      });
    });
  }

  document.addEventListener('astro:page-load', initFAQ);
  initFAQ();
</script>
