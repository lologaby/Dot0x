---
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---
<nav class="fixed top-0 w-full z-50 glass-panel border-b border-white/10 px-4 md:px-6 py-3 md:py-4">
  <div class="max-w-7xl mx-auto flex items-center justify-between">
    <a href={translatePath('/')} class="text-[1.1rem] sm:text-xl md:text-2xl font-bold tracking-tighter metallic-gradient flex items-center min-w-[200px] sm:min-w-[280px]" id="logo-container">
      <span id="typewriter" class="inline-block"></span>
      <span class="inline-block w-2 bg-white ml-1 h-6 animate-[blink_1s_step-end_infinite]"></span>
    </a>

    <!-- Desktop nav links -->
    <div class="hidden md:flex gap-8 items-center">
      <a href={translatePath('/')} class="text-sm font-medium text-neutral-400 hover:text-white transition-colors">{t('nav.home')}</a>
      <a href={translatePath('/services')} class="text-sm font-medium text-neutral-400 hover:text-white transition-colors">{t('nav.services')}</a>
      <a href={translatePath('/about')} class="text-sm font-medium text-neutral-400 hover:text-white transition-colors">{t('nav.about')}</a>
    </div>

    <!-- Right side: flags + contact + hamburger -->
    <div class="flex gap-4 items-center">
      <!-- Language toggle -->
      <div class="flex items-center gap-1 text-lg">
        <a href={`${base}/es`} class={`transition-all hover:scale-110 leading-none ${lang === 'es' ? 'opacity-100 scale-110 ring-2 ring-white/60 rounded-sm shadow-[0_0_10px_rgba(255,255,255,0.6)]' : 'opacity-40 hover:opacity-80'}`} title="Español (PR)">🇵🇷</a>
        <span class="text-white/30 text-sm font-light select-none">/</span>
        <a href={`${base}/en`} class={`transition-all hover:scale-110 leading-none ${lang === 'en' ? 'opacity-100 scale-110 ring-2 ring-white/60 rounded-sm shadow-[0_0_10px_rgba(255,255,255,0.6)]' : 'opacity-40 hover:opacity-80'}`} title="English (US)">🇺🇸</a>
      </div>

      <!-- Contact button (desktop only) -->
      <a href={translatePath('/contact')} class="hidden md:block px-4 py-2 bg-white/10 hover:bg-white/20 border border-white/20 rounded-full text-sm font-medium transition-all">{t('nav.contact')}</a>

      <!-- Hamburger (mobile only) -->
      <button id="mobile-menu-btn" aria-label="Open menu" aria-expanded="false"
        class="md:hidden flex flex-col gap-1.5 p-2 rounded-lg hover:bg-white/10 transition-colors">
        <span class="hamburger-line block w-5 h-0.5 bg-white transition-all duration-300"></span>
        <span class="hamburger-line block w-5 h-0.5 bg-white transition-all duration-300"></span>
        <span class="hamburger-line block w-5 h-0.5 bg-white transition-all duration-300"></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden hidden border-t border-white/10 mt-3 pt-4 pb-2 flex-col gap-1">
    <a href={translatePath('/')} class="block px-4 py-3 text-sm font-medium text-neutral-300 hover:text-white hover:bg-white/5 rounded-lg transition-colors">{t('nav.home')}</a>
    <a href={translatePath('/services')} class="block px-4 py-3 text-sm font-medium text-neutral-300 hover:text-white hover:bg-white/5 rounded-lg transition-colors">{t('nav.services')}</a>
    <a href={translatePath('/about')} class="block px-4 py-3 text-sm font-medium text-neutral-300 hover:text-white hover:bg-white/5 rounded-lg transition-colors">{t('nav.about')}</a>
    <a href={translatePath('/contact')} class="block px-4 py-3 text-sm font-medium text-neutral-300 hover:text-white hover:bg-white/5 rounded-lg transition-colors">{t('nav.contact')}</a>
  </div>
</nav>

<script>
  // Typewriter
  const text = "Dot0x - Puerto Rico";
  const speed = 100;
  let i = 0;

  function typeWriter() {
    const el = document.getElementById("typewriter");
    if (el && i < text.length) {
      el.innerHTML += text.charAt(i);
      i++;
      setTimeout(typeWriter, speed);
    }
  }

  document.addEventListener('astro:page-load', () => {
    i = 0;
    const el = document.getElementById("typewriter");
    if (el) el.innerHTML = '';
    typeWriter();
  });

  typeWriter();

  // Mobile menu toggle
  function initMobileMenu() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const lines = btn?.querySelectorAll('.hamburger-line');

    btn?.addEventListener('click', () => {
      const isOpen = menu?.classList.toggle('hidden') === false;
      menu?.classList.toggle('flex', isOpen);
      btn.setAttribute('aria-expanded', String(isOpen));

      // Animate hamburger to X
      if (lines && lines.length === 3) {
        if (isOpen) {
          (lines[0] as HTMLElement).style.transform = 'translateY(8px) rotate(45deg)';
          (lines[1] as HTMLElement).style.opacity = '0';
          (lines[2] as HTMLElement).style.transform = 'translateY(-8px) rotate(-45deg)';
        } else {
          (lines[0] as HTMLElement).style.transform = '';
          (lines[1] as HTMLElement).style.opacity = '';
          (lines[2] as HTMLElement).style.transform = '';
        }
      }
    });

    // Close menu on link click
    menu?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        menu.classList.add('hidden');
        menu.classList.remove('flex');
        btn?.setAttribute('aria-expanded', 'false');
        if (lines) {
          (lines[0] as HTMLElement).style.transform = '';
          (lines[1] as HTMLElement).style.opacity = '';
          (lines[2] as HTMLElement).style.transform = '';
        }
      });
    });
  }

  document.addEventListener('astro:page-load', initMobileMenu);
  initMobileMenu();
</script>
