---
interface Props {
  lang: 'es' | 'en';
}
const { lang } = Astro.props;

// Row 1 — AI & Automation stack
const row1 = [
  { name: 'Anthropic',        slug: 'anthropic'         },
  { name: 'OpenAI',           slug: 'openai'            },
  { name: 'Google Gemini',    slug: 'googlegemini'      },
  { name: 'Make',             slug: 'make'              },
  { name: 'Zapier',           slug: 'zapier'            },
  { name: 'n8n',              slug: 'n8n'               },
  { name: 'HubSpot',          slug: 'hubspot'           },
  { name: 'Slack',            slug: 'slack'             },
  { name: 'WhatsApp',         slug: 'whatsapp'          },
];

// Row 2 — Infrastructure & Productivity stack
const row2 = [
  { name: 'GitHub',           slug: 'github'            },
  { name: 'AWS',              slug: 'amazonaws'         },
  { name: 'Google Cloud',     slug: 'googlecloud'       },
  { name: 'Microsoft Azure',  slug: 'microsoftazure'    },
  { name: 'Docker',           slug: 'docker'            },
  { name: 'Google Workspace', slug: 'googleworkspace'   },
  { name: 'Microsoft 365',    slug: 'microsoftoffice'   },
  { name: 'Notion',           slug: 'notion'            },
  { name: 'Airtable',         slug: 'airtable'          },
];

const title = lang === 'es'
  ? 'El ecosistema que impulsa tu negocio'
  : 'The ecosystem powering your business';

const subtitle = lang === 'es'
  ? 'Implementamos, configuramos y gestionamos las mejores plataformas del mundo.'
  : 'We deploy, configure, and manage the world\'s leading platforms.';
---

<section class="py-14 md:py-20 border-b border-white/5 overflow-hidden">
  <!-- Heading -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 text-center mb-10 md:mb-14 reveal">
    <p class="text-xs font-bold tracking-[0.25em] uppercase text-neutral-500 mb-3">
      {lang === 'es' ? 'Herramientas que Implementamos' : 'Tools We Deploy & Manage'}
    </p>
    <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-white mb-3">{title}</h2>
    <p class="text-neutral-400 text-base md:text-lg max-w-2xl mx-auto">{subtitle}</p>
  </div>

  <!-- Row 1 — scrolls left -->
  <div class="relative mb-4">
    <!-- Edge fade masks -->
    <div class="pointer-events-none absolute left-0 top-0 bottom-0 w-20 md:w-32 z-10"
      style="background: linear-gradient(to right, #0d0d0f, transparent);"></div>
    <div class="pointer-events-none absolute right-0 top-0 bottom-0 w-20 md:w-32 z-10"
      style="background: linear-gradient(to left, #0d0d0f, transparent);"></div>

    <div class="logo-track flex gap-4 md:gap-6 w-max" style="animation: logoScrollLeft 38s linear infinite;">
      {[...row1, ...row1].map(tool => (
        <div class="logo-card flex flex-col items-center justify-center gap-2 px-5 py-4 rounded-2xl border border-white/8 bg-white/[0.03] hover:bg-white/8 hover:border-white/20 transition-all duration-300 group min-w-[100px] md:min-w-[120px] cursor-default">
          <img
            src={`https://cdn.simpleicons.org/${tool.slug}`}
            alt={tool.name}
            width="32" height="32"
            class="w-7 h-7 md:w-8 md:h-8 opacity-40 group-hover:opacity-100 transition-all duration-300"
            style="filter: grayscale(1) brightness(2);"
            onmouseover="this.style.filter='none'"
            onmouseout="this.style.filter='grayscale(1) brightness(2)'"
            loading="lazy"
          />
          <span class="text-[10px] md:text-xs text-neutral-600 group-hover:text-neutral-300 transition-colors whitespace-nowrap font-medium">{tool.name}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Row 2 — scrolls right -->
  <div class="relative">
    <div class="pointer-events-none absolute left-0 top-0 bottom-0 w-20 md:w-32 z-10"
      style="background: linear-gradient(to right, #0d0d0f, transparent);"></div>
    <div class="pointer-events-none absolute right-0 top-0 bottom-0 w-20 md:w-32 z-10"
      style="background: linear-gradient(to left, #0d0d0f, transparent);"></div>

    <div class="logo-track flex gap-4 md:gap-6 w-max" style="animation: logoScrollRight 44s linear infinite;">
      {[...row2, ...row2].map(tool => (
        <div class="logo-card flex flex-col items-center justify-center gap-2 px-5 py-4 rounded-2xl border border-white/8 bg-white/[0.03] hover:bg-white/8 hover:border-white/20 transition-all duration-300 group min-w-[100px] md:min-w-[120px] cursor-default">
          <img
            src={`https://cdn.simpleicons.org/${tool.slug}`}
            alt={tool.name}
            width="32" height="32"
            class="w-7 h-7 md:w-8 md:h-8 opacity-40 group-hover:opacity-100 transition-all duration-300"
            style="filter: grayscale(1) brightness(2);"
            onmouseover="this.style.filter='none'"
            onmouseout="this.style.filter='grayscale(1) brightness(2)'"
            loading="lazy"
          />
          <span class="text-[10px] md:text-xs text-neutral-600 group-hover:text-neutral-300 transition-colors whitespace-nowrap font-medium">{tool.name}</span>
        </div>
      ))}
    </div>
  </div>
</section>
